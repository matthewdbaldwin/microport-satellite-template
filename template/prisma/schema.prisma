// __APP_NAME__ schema. Prisma 7 + driver adapter (adapter-pg).
//
// FK-table naming: this template emits @@map("__FK_TABLE__"). Pick "users"
// (snake-plural, like sp/op) or "User" (default, like rp/cp/ep) at mint time —
// all hand-written SQL must match. feedback_prisma_migration_fk_table_naming_per_repo.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7.8 removed `url` from the schema — the connection URL lives in
  // prisma.config.mjs (Migrate) + the PrismaPg adapter (runtime).
  // feedback_prisma_config_mjs_not_ts.
  provider = "postgresql"
}

enum Role {
  __PRIMARY_ROLE__
  admin
  superuser
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  name        String?
  role        Role      @default(__PRIMARY_ROLE__)
  active      Boolean   @default(true)
  locale      String?   @default("en-US")
  password    String?   // null for SSO-only users
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sessions    Session[]

  @@map("__FK_TABLE__")
}

// Server-side session for jti-bearing tokens (B1 Phase 4b) — revocation + UI.
model Session {
  id         String    @id @default(cuid())
  jti        String    @unique
  userId     Int
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt  DateTime?
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("sessions")
}

// Inbound SSO-lifecycle event audit + idempotency store (fleet parity). Every
// event salesport delivers to /api/sso/lifecycle/event is logged here; the
// unique senderEventId (salesport's LifecycleOutbox.id, from the
// X-Lifecycle-Event-Id header) makes retry dedup a single findUnique.
// See src/routes/ssoLifecycle.js.
model UserLifecycleEvent {
  id            Int       @id @default(autoincrement())
  senderEventId String?   @unique
  email         String
  kind          String // grant | revoke | disable | reactivate
  prevRole      String?
  newRole       String?
  actorEmail    String?
  actorRole     String?
  payload       Json
  receivedAt    DateTime  @default(now())
  processedAt   DateTime?
  error         String?   @db.Text

  @@index([email])
  @@index([receivedAt])
  @@map("user_lifecycle_events")
}
