# __APP_NAME__ — environment

# ── Database (Prisma 7 + adapter-pg) ─────────────────────────────────────────
DATABASE_URL=postgresql://__APP_SLUG__:__APP_SLUG__@localhost:5432/__DB_NAME__
# Optional split for migrations under a higher-priv role (B2). Falls back to DATABASE_URL.
# MIGRATE_DATABASE_URL=

# ── SSO (SalesPort is the hub; this app is a spoke) ──────────────────────────
SALESPORT_JWT_ISSUER=https://salesport.local
SALESPORT_JWT_PUBLIC_KEY=          # base64 of the RS256 public PEM
JWT_SECRET=                        # local-login HS256 secret (optional)
COOKIE_DOMAIN=
# SsoClaims contract check on the verify path. enforce | warn | off.
# Break-glass to 'warn' reverts to non-blocking without a redeploy.
SSO_CLAIMS_MODE=enforce
# ── HubPort IdP lift (all INERT until provisioned) ───────────────────────────
# Static second acceptor: HubPort's public key (base64 PEM). Set at the issuer
# flip so this app accepts HubPort-signed tokens without a fleet-wide redeploy.
SALESPORT_JWT_PUBLIC_KEY_B=
# JWKS URL for rotation-friendly key discovery. Strictly ADDITIVE — the static
# keys above stay the fallback, so a JWKS outage can never fail auth closed.
HUBPORT_JWKS_URL=
# HMAC secret for HubPort-emitted lifecycle events (x-hubport-signature). Blank
# → HubPort's emitter is skipped; SalesPort's x-salesport-signature still works.
HUBPORT_LIFECYCLE_SECRET=
# Inbound lifecycle HMAC from SalesPort (x-salesport-signature).
SALESPORT_LIFECYCLE_SECRET=

# ── Cross-app webhooks (canonical WEBHOOK_SECRET_<FROM>_<TO>) ─────────────────
# Set the matching secret on the SENDER and this RECEIVER. reference_webhook_topology.
WEBHOOK_SECRET_SALESPORT___APP_SLUG__=
WEBHOOK_SECRET___APP_SLUG___SALESPORT=
# HubPort is the central bug-report queue + IdP since 2026-07-11. This is the
# __APP_SLUG__→HubPort channel secret (used as BUGREPORT_FORWARD_SECRET below).
WEBHOOK_SECRET___APP_SLUG___HUBPORT=
SALESPORT_API_URL=http://localhost:4000

# ── Bug-report forward (hub-first, Matt 2026-07-09) ──────────────────────────
# BLANK → reports go to SalesPort's legacy JSON-only /cross-app (the pre-cutover
# default). Set BOTH to route to HubPort's central queue, which also accepts the
# multipart screenshot leg: URL = the hub API base, SECRET = the value of
# WEBHOOK_SECRET___APP_SLUG___HUBPORT above. bug-report-fanout.
BUGREPORT_FORWARD_URL=
BUGREPORT_FORWARD_SECRET=

# ── Misc ─────────────────────────────────────────────────────────────────────
PORT=4100
WEB_ORIGIN=http://localhost:3100
NODE_ENV=development
# EMAIL_DISABLED=true   # dev safety; prod task role also omits ses:SendEmail unless this app emails
