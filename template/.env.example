# __APP_NAME__ — environment

# ── Database (Prisma 7 + adapter-pg) ─────────────────────────────────────────
DATABASE_URL=postgresql://__APP_SLUG__:__APP_SLUG__@localhost:5432/__DB_NAME__
# Optional split for migrations under a higher-priv role (B2). Falls back to DATABASE_URL.
# MIGRATE_DATABASE_URL=

# ── SSO (SalesPort is the hub; this app is a spoke) ──────────────────────────
SALESPORT_JWT_ISSUER=https://salesport.local
SALESPORT_JWT_PUBLIC_KEY=          # base64 of the RS256 public PEM
JWT_SECRET=                        # local-login HS256 secret (optional)
COOKIE_DOMAIN=
# SsoClaims contract check on the verify path. enforce | warn | off.
# Break-glass to 'warn' reverts to non-blocking without a redeploy.
SSO_CLAIMS_MODE=enforce

# ── Cross-app webhooks (canonical WEBHOOK_SECRET_<FROM>_<TO>) ─────────────────
# Set the matching secret on the SENDER and this RECEIVER. reference_webhook_topology.
WEBHOOK_SECRET_SALESPORT___APP_SLUG__=
WEBHOOK_SECRET___APP_SLUG___SALESPORT=
SALESPORT_API_URL=http://localhost:4000

# ── Misc ─────────────────────────────────────────────────────────────────────
PORT=4100
WEB_ORIGIN=http://localhost:3100
NODE_ENV=development
# EMAIL_DISABLED=true   # dev safety; prod task role also omits ses:SendEmail unless this app emails
